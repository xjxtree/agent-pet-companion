    "connections.failure.rejected" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "PetCore could not complete this operation. Check the current connection state, then retry." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "PetCore 未能完成此操作。请检查当前连接状态后重试。" } } } },
    "connections.failure.partial" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The operation completed for only some selected agents. Open Technical Details, then retry." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "操作仅对部分所选 Agent 完成。请展开“技术详情”后重试。" } } } },
    "connections.failure.invalid_response" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "PetCore returned an invalid response. Restore the local service, then retry." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "PetCore 返回了无效响应。请恢复本地服务后重试。" } } } },
    "connections.failure.invalid_request" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The operation no longer has a valid Agent target. Select an Agent and try again." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "此操作已没有有效的 Agent 目标。请选择 Agent 后重试。" } } } },
    "connections.failure.unknown" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The connection operation could not be completed. Try again or open Service & Diagnostics." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "连接操作未能完成。请重试或打开“服务与诊断”。" } } } },
    "connections.checks.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Checks" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "检查项" } } } },
    "connections.checks.empty" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "This snapshot contains no checks. Run a full check again." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "当前快照没有返回检查项。请重新执行完整检查。" } } } },
    "connections.managed.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Managed Connection" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "受管连接" } } } },
    "connections.managed.detail" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Install and repair change only the managed connection files listed in the inspector. Uninstall never removes the agent or user projects." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "安装和修复只修改检查器列出的受管连接文件；卸载不会删除 Agent 本体或用户项目。" } } } },
    "connections.action.repair" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Repair Connection" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "修复连接" } } } },
    "connections.action.install_repair" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Install or Repair" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "安装或修复" } } } },
    "connections.action.repair_accessibility_format" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Install or repair the %@ connection" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "安装或修复 %@ 连接" } } } },
    "connections.action.uninstall_accessibility_format" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Uninstall the %@ connection" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "卸载 %@ 连接" } } } },
    "connections.hint.uninstall" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Removes only managed connection files, not the agent." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "仅移除受管连接文件，不卸载 Agent" } } } },
    "connections.snapshot.description_format" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "PetCore has not returned check results for %@. You can run a full check now." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "PetCore 尚未返回 %@ 的检查结果。你仍可立即执行完整检查。" } } } },
    "connections.action.check_source_format" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Check %@" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "检查 %@" } } } },
    "connections.confirm.repair_unavailable" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The app cannot automatically repair a managed connection issue in the current state." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "当前状态没有可由 App 自动修复的受管连接问题。" } } } },
    "connections.confirm.repair_files_intro" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The following managed connection files will be installed or updated:" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "将安装或更新以下受管连接文件：" } } } },
    "connections.confirm.repair_safety" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Agent credentials are not read, and unlisted user files are not changed." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "不会读取 Agent 凭据，也不会修改未列出的用户文件。" } } } },
    "connections.confirm.uninstall_unavailable" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "No managed connection is currently available to uninstall." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "当前没有可卸载的受管连接。" } } } },
    "connections.confirm.uninstall_files_intro" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The following managed connection files or settings will be removed:" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "将移除以下受管连接文件或配置：" } } } },
    "connections.confirm.paths_unreported" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The inspector did not report specific paths." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "检查器当前未报告具体路径。" } } } },
    "connections.hint.repair_preview" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Review managed file locations before confirming the write." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "先预览受管文件位置，再确认写入" } } } },
    "connections.hint.repair_none" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "This check found no issue that can be repaired automatically." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "当前检查没有发现可自动修复的问题" } } } },
    "connections.hint.repair_manual" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Follow the check item instructions to resolve this issue manually." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "当前问题需要按检查项说明手动处理" } } } },
    "connections.action.recheck" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Check Again" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "重新检查" } } } },
    "connections.hint.recheck" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Refresh this Agent's local connection checks and verification evidence." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "刷新此 Agent 的本地连接检查与验证证据" } } } },
    "connections.action.test_channel" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Test Channel" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "测试通道" } } } },
    "connections.hint.test" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Tests only the local diagnostic event path; it does not mark a real agent as verified." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "只测试本地诊断事件链路，不会标记真实 Agent 已验证" } } } },
    "connections.test.detail_format" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "“Test Channel” validates only the local CLI, RPC, and event persistence path. Real verification requires running a real %@ task." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "“测试通道”只验证本地 CLI、RPC 与事件持久化链路；真实验证需要运行一次真实的 %@ 任务。" } } } },
    "connections.check.accessibility_format" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "%@: %@. %@" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "%@：%@，%@" } } } },
    "connections.check.name.agent_cli" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Agent CLI" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "Agent CLI" } } } },
    "connections.check.name.event_cli" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Local Event CLI" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "本地事件 CLI" } } } },
    "connections.check.name.agent_version" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Agent Version" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "Agent 版本" } } } },
    "connections.check.name.managed_connector" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Managed Connector" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "托管连接器" } } } },
    "connections.check.name.claude_hooks_policy" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Claude Hooks Policy" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "Claude Hooks 策略" } } } },
    "connections.check.name.host_runtime" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Host Runtime" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "宿主运行时" } } } },
    "connections.check.name.host_verification" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Host Verification" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "宿主验证" } } } },
    "connections.check.name.event_delivery" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Event Delivery" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "事件回传" } } } },
    "connections.check.name.channel_test" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Local Channel Test" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "本地通道自检" } } } },
    "connections.check.name.app_server" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Codex App Server" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "Codex App Server" } } } },
    "connections.check.name.host_server" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "OpenCode Server" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "OpenCode Server" } } } },
    "connections.check.name.generic" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Connection Check" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "连接检查项" } } } },
    "connections.check.description.agent_cli" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Checks whether the selected agent command is available to the connection environment. Install or expose the agent CLI, then check again." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "检查连接环境能否使用所选 Agent 命令。若不可用，请安装 Agent CLI 或让当前环境可找到它，然后重新检查。" } } } },
    "connections.check.description.event_cli" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Checks whether Agent Pet Companion's local event command is installed. Use Install or Repair if it is missing." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "检查 Agent Pet Companion 的本地事件命令是否已安装。若缺失，请使用“安装或修复”。" } } } },
    "connections.check.description.agent_version" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Checks whether the detected agent version supports this connector. Update the agent if the version is missing or unsupported." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "检查当前 Agent 版本是否受连接器支持。若版本缺失或不受支持，请更新 Agent。" } } } },
    "connections.check.description.managed_connector" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Checks the app-managed connector files and settings. Review the managed locations, then use Install or Repair." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "检查 App 管理的连接器文件与设置。请先查看受管位置，再使用“安装或修复”。" } } } },
    "connections.check.description.claude_hooks_policy" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Checks whether Claude Hooks policies permit Agent Pet Companion. disableAllHooks, allowManagedHooksOnly, or another managed policy may block Hooks; adjust the policy or contact your administrator, then check again." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "检查 Claude Hooks 策略是否允许 Agent Pet Companion。disableAllHooks、allowManagedHooksOnly 或其他管理策略可能阻止 Hooks；请调整策略或联系管理员，然后重新检查。" } } } },
    "connections.check.description.host_runtime" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Checks whether the agent host loaded its managed connector. Restart the agent after a repair, then check again." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "检查 Agent 宿主是否已加载受管连接器。修复后请重启 Agent，再重新检查。" } } } },
    "connections.check.description.host_verification" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Checks host trust and connector loading for this agent. Follow the host guidance and run a real agent task before checking again." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "检查该 Agent 的宿主信任与连接器加载情况。请按宿主指引处理并运行一次真实 Agent 任务，再重新检查。" } } } },
    "connections.check.description.event_delivery" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Checks whether the local event command can reach PetCore. Repair the connector or local service, then check again." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "检查本地事件命令能否连接 PetCore。请修复连接器或本地服务，然后重新检查。" } } } },
    "connections.check.description.channel_test" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Checks only the local diagnostic CLI, RPC, and event persistence path. It does not verify a real agent task." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "只检查本地诊断 CLI、RPC 与事件持久化链路，不代表真实 Agent 任务已验证。" } } } },
    "connections.check.description.app_server" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Checks whether Codex App Server is available for connector workflows. Update or enable Codex, then check again." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "检查 Codex App Server 是否可用于连接器工作流。请更新或启用 Codex，然后重新检查。" } } } },
    "connections.check.description.host_server" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Checks whether the OpenCode server is available to the managed connector. Update or restart OpenCode, then check again." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "检查 OpenCode Server 是否可供受管连接器使用。请更新或重启 OpenCode，然后重新检查。" } } } },
    "connections.check.description.generic" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Checks a supported connection condition. Refresh the check and follow the managed-connection guidance if it still needs attention." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "检查一个受支持的连接条件。请刷新检查；若仍需处理，请按受管连接指引操作。" } } } },
    "connections.check.detail_format" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Status: %@. %@" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "状态：%@。%@" } } } },
    "connections.verification.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Real Agent Verification" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "Agent 侧真实验证" } } } },
    "connections.verification.not_run_title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Real task not run" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "尚未运行真实任务" } } } },
    "connections.verification.not_run_detail" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Run a local connection check first; real-task evidence is tracked separately." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "请先运行本机连接检查；真实任务证据会作为独立状态记录。" } } } },
    "connections.verification.verified_title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Real agent activity verified" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "真实 Agent 活动已验证" } } } },
    "connections.verification.action_title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Run a real agent task" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "请运行真实 Agent 任务" } } } },
    "connections.verification.pending_title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Awaiting real agent activity" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "等待真实 Agent 活动" } } } },
    "connections.verification.not_required_title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Real-agent verification not required" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "无需真实 Agent 验证" } } } },
    "connections.verification.verified_detail" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "A real task reached the local event channel from this agent." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "此 Agent 的真实任务已到达本地事件通道。" } } } },
    "connections.verification.action_detail" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Run a real task in this Agent, then choose Verify to refresh the evidence." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "请在此 Agent 中运行一次真实任务，再选择“验证”刷新证据。" } } } },
    "connections.verification.pending_detail" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "No qualifying real-agent event has been observed yet." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "尚未观察到符合条件的真实 Agent 事件。" } } } },
    "connections.verification.not_required_detail" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "This connector does not require a real-agent verification step." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "此连接无需真实 Agent 验证步骤。" } } } },
    "connections.verification.instruction_format" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Run a real %@ task, then verify again. The local channel test cannot replace this step." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "请运行一次真实的 %@ 任务，再重新验证；本地通道测试不能替代这一步。" } } } },
    "connections.metadata.cwd" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Check directory" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "检查目录" } } } },
    "connections.metadata.last_receipt" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Latest host receipt" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "最近宿主回执" } } } },
