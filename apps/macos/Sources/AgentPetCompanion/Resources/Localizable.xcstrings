    "connections.environment.privacy_detail" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Checks only managed connection files, CLI availability, and explicit event channels. Agent tokens, cookies, API keys, and other credentials are never read." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "只检查受管连接文件、CLI 可用性和显式事件通道；不读取 Agent 的令牌、Cookie、API Key 或其他凭据。" } } } },
