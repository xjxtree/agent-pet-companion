    "studio.brief.timing_detail" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "20 FPS requires twice as many authored frames. Timing becomes fixed in this pet revision; playback settings never retime the action." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "20 FPS 需要两倍制作帧；时序生成后随此宠物 revision 固定，播放设置不会改变动作速度或时长。" } } } },
