    "studio.session.welcome_detail" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Complete the creation brief to begin." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "完成左侧创作 brief 后开始制作。" } } } },
    "studio.session.output_contract_title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Output Contract" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "输出合同" } } } },
    "studio.session.output_contract_detail" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The result must include idle, start, tool, waiting, review, done, and failed; native frame rate must be 10 or 20 FPS and every action must be fixed at 1 or 2 seconds." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "生成结果必须包含 idle、start、tool、waiting、review、done、failed 七个状态；原生帧率只能为 10 或 20 FPS，每个动作固定为 1 秒或 2 秒。" } } } },
    "studio.session.output_privacy" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Only task-scoped safe copies are used. Unvalidated assets never enter the pet library." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "仅使用任务所需的安全副本；未经校验的资产不会进入宠物库。" } } } },
    "studio.session.preparing" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Preparing the local session…" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "正在准备本地会话…" } } } },
