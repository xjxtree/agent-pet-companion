    "connections.capabilities.unavailable" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "PetCore has not returned a capability list. Run a full check first." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "当前 PetCore 尚未返回能力清单。完成完整检查后再查看。" } } } },
