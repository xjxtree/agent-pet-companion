    "studio.brief.references_contract" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Up to 4 PNG or WebP images · 20 MiB each · 40 MiB total · 16 MP each" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "最多 4 张 PNG 或 WebP · 单张 20 MiB · 总计 40 MiB · 单张 1600 万像素" } } } },
    "studio.brief.references_panel_title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Choose Reference Images" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "选择参考图" } } } },
    "studio.brief.references_panel_message" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Choose PNG or WebP images for character appearance or style reference." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "选择用于角色形象或风格参考的 PNG 或 WebP 图片。" } } } },
    "studio.brief.references_issue.too_many" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "You can add at most 4 reference images." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "参考图最多可添加 4 张。" } } } },
    "studio.brief.references_issue.unsupported" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Use a PNG or WebP reference image." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "请选择 PNG 或 WebP 参考图。" } } } },
    "studio.brief.references_issue.unavailable" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "That reference image is unavailable or unreadable." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "这张参考图不可用或无法读取。" } } } },
    "studio.brief.references_issue.too_large" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Each reference image must be 20 MiB or smaller." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "每张参考图不得超过 20 MiB。" } } } },
    "studio.brief.references_issue.total_too_large" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Reference images must total 40 MiB or less." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "参考图总大小不得超过 40 MiB。" } } } },
    "studio.brief.references_issue.too_many_pixels" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Each reference image must contain no more than 16 megapixels." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "每张参考图不得超过 1600 万像素。" } } } },
