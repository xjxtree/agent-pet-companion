    "connections.environment.runtime_footer" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Identifies the App/PetCore contract environment used for this agent check. Service health is available in Service & Diagnostics." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "仅用于说明本次 Agent 检查发生在哪个 App/PetCore 合同环境；服务健康请在“服务与诊断”查看。" } } } },
    "connections.environment.install_locations_empty" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Managed connection locations appear after a check." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "完成检查后显示由 App 管理的连接位置。" } } } },
