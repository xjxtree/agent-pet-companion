    "studio.brief.references_drop_empty" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Drop images here, or choose files" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "拖入图片，或点按选择" } } } },
