    "app.update.checking.detail" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The App is looking for the latest verified release for this Mac." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "App 正在查找适用于此 Mac、经过安全校验的最新正式版本。" } } } },
    "app.update.available.title_format" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Version %@ Is Available" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "新版 %@ 可用" } } } },
    "app.update.available.compact_format" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Update %@ Available" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "新版 %@ 可用" } } } },
    "app.update.available.detail" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Download the build made for this Mac. After you replace the App, the new version finishes updating its managed services and Agent integrations for you." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "下载为这台 Mac 准备的版本。替换 App 后，新版会为你完成托管服务和 Agent 集成的更新。" } } } },
    "app.update.data_reassurance" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Your pets, settings, and history stay exactly where they are." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "你的宠物、设置和历史会完整保留。" } } } },
    "app.update.asset.detail_format" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "%@ · %@" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "%@ · %@" } } } },
    "app.update.release.verified" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The version, download, and checksum match the official GitHub Release." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "版本、下载地址和校验和均与官方 GitHub Release 一致。" } } } },
    "app.update.architecture.apple_silicon" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Apple silicon" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "Apple 芯片" } } } },
    "app.update.architecture.intel" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Intel" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "Intel 芯片" } } } },
    "app.update.current.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "You’re up to date" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "当前已是最新版" } } } },
    "app.update.current.detail_format" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Version %@ is the latest stable release." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "%@ 是最新稳定版本。" } } } },
    "app.update.failure.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Couldn’t check for updates" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "未能检查更新" } } } },
    "app.update.failure.download_title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Couldn’t Open the Download" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "未能打开下载" } } } },
    "app.update.failure.network_detail" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "GitHub could not be reached. Nothing changed; check your connection and try again." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "暂时无法连接 GitHub。任何内容都没有改变，请检查网络后重试。" } } } },
    "app.update.failure.verification_detail" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The latest Release did not pass the App’s safety checks, so no download was offered. Try again later." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "最新 Release 未通过 App 的安全校验，因此没有提供下载。请稍后再试。" } } } },
    "app.update.failure.open_detail" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The browser did not open the download. Try again, or open the verified Release page and download this Mac’s build there." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "浏览器未能打开下载。你可以重试，或打开已验证的 Release 页面，在那里下载适合这台 Mac 的版本。" } } } },
    "app.update.install.required" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Finish Installing the New App" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "完成新版 App 安装" } } } },
    "app.update.install.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Move the New App into Applications" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "将新版 App 移入“应用程序”" } } } },
    "app.update.install.invalid.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Download a Complete Copy" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "重新下载完整版本" } } } },
    "app.update.install.invalid.subtitle" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "This App copy cannot safely update its bundled components. Download the official release again. Your pets, settings, history, and current work are untouched." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "此 App 副本无法安全更新随附组件。请重新下载官方 Release；你的宠物、设置、历史与当前工作不会改变。" } } } },
    "app.update.install.restart_failed.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Open the New Version Manually" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "手动打开新版" } } } },
    "app.update.install.restart_failed.subtitle" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The new App is ready, but the current App could not reopen it automatically. Open Applications, quit this App, then open the new version. Your pets, settings, and work are preserved." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "新版 App 已准备好，但当前 App 无法自动重新打开它。请先打开“应用程序”，退出当前 App，再打开新版。你的宠物、设置和进行中的工作都会保留。" } } } },
    "app.update.install.version_format" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Version %@" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "版本 %@" } } } },
    "app.update.install.subtitle" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "This build is not Developer ID-signed, so macOS does not permit a seamless in-place update. It takes three short steps." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "当前版本未使用 Developer ID 签名，因此 macOS 不允许无感原位更新。只需完成下面三步。" } } } },
    "app.update.install.step.download.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Download and unzip" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "下载并解压" } } } },
    "app.update.install.step.download.detail" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Use the architecture-specific ZIP offered by the App. Finder normally expands it in Downloads." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "使用 App 提供的对应芯片 ZIP；Finder 通常会在“下载”文件夹中自动解压。" } } } },
    "app.update.install.step.replace.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Replace the App" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "替换 App" } } } },
    "app.update.install.step.replace.detail" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Quit the old App if it is running. Drag AgentPetCompanion.app into Applications and choose Replace." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "如果旧版仍在运行，请先退出。将 AgentPetCompanion.app 拖入“应用程序”，然后选择“替换”。" } } } },
    "app.update.install.step.open.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Open the new version" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "打开新版" } } } },
    "app.update.install.step.open.detail" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "In Applications, Control-click AgentPetCompanion and choose Open. If macOS asks, allow it in Privacy & Security." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "在“应用程序”中按住 Control 点击 AgentPetCompanion 并选择“打开”。如 macOS 提示，请在“隐私与安全性”中允许打开。" } } } },
    "app.update.install.step.accessibility_format" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Step %d. %@. %@" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "第 %d 步。%@。%@" } } } },
    "app.update.convergence.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Finishing the New Version Setup" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "正在完成新版设置" } } } },
    "app.update.convergence.detail" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The App is updating its local service and the Agent integrations you already use. This normally takes only a moment." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "App 正在更新本地服务和你已经使用的 Agent 集成，通常只需片刻。" } } } },
    "app.update.convergence.waiting.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Your Current Work Comes First" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "先让当前任务完成" } } } },
    "app.update.convergence.waiting.detail" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "A pet creation or another protected operation is still active. The update will continue automatically as soon as it finishes." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "宠物制作或另一项受保护操作仍在进行。任务完成后，更新会自动继续。" } } } },
    "app.update.convergence.complete.title_format" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Updated to Version %@" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "已更新至版本 %@" } } } },
    "app.update.convergence.complete.detail" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The local service, CLI, bundled pets, and your managed Agent integrations are ready." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "本地服务、CLI、内置宠物和由 App 管理的 Agent 集成都已就绪。" } } } },
    "app.update.convergence.attention.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Finish Setting Up the Update" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "完成更新设置" } } } },
    "app.update.convergence.attention.detail" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The App could not verify every bundled component or managed Agent integration. You can keep using your existing pets and data, then retry." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "App 未能验证全部随附组件或受管 Agent 集成。你仍可使用现有宠物和数据，然后重试。" } } } },
    "app.update.convergence.action.retry" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Retry Update" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "重试更新" } } } },
    "app.update.convergence.action.open_connections" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Open Agent Connections" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "打开 Agent 连接" } } } },
    "app.update.convergence.action.open_diagnostics" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Open Service & Diagnostics" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "打开服务与诊断" } } } },
    "app.update.convergence.maker_blocked" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Finishing the update before starting new pet work" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "正在完成更新，完成后即可开始新的宠物制作" } } } }
  },
  "version" : "1.0"
}
