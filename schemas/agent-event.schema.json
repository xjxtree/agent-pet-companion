{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentpetcompanion.local/schemas/agent-event.schema.json",
  "title": "Agent Pet Companion Normalized Persisted Event",
  "description": "The complete normalized event record exposed by PetCore and persisted in SQLite. Display copy and payload metadata use closed vocabularies. Bounded user/assistant display messages are explicit; raw hook input, commands, tool output, and transcripts are never represented by this schema.",
  "type": "object",
  "required": [
    "id",
    "source",
    "project_path",
    "session_id",
    "event_type",
    "title",
    "detail",
    "payload_json",
    "created_at"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1, "maxLength": 256 },
    "source": { "enum": ["codex", "claude_code", "pi", "opencode"] },
    "project_path": { "type": ["string", "null"], "maxLength": 1024 },
    "session_id": { "type": ["string", "null"], "maxLength": 256 },
    "event_type": { "enum": ["start", "tool", "waiting", "review", "done", "failed"] },
    "title": { "type": "string" },
    "detail": { "type": "null" },
    "payload_json": { "$ref": "#/$defs/persistedEnvelope" },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "oneOf": [
    { "properties": { "event_type": { "const": "start" }, "title": { "const": "开始处理" } } },
    { "properties": { "event_type": { "const": "tool" }, "title": { "const": "执行工具" } } },
    { "properties": { "event_type": { "const": "waiting" }, "title": { "const": "等待确认" } } },
    { "properties": { "event_type": { "const": "review" }, "title": { "const": "待查看" } } },
    { "properties": { "event_type": { "const": "done" }, "title": { "const": "完成" } } },
    { "properties": { "event_type": { "const": "failed" }, "title": { "const": "失败" } } }
  ],
  "additionalProperties": false,
  "$defs": {
    "persistedEnvelope": {
      "type": "object",
      "required": [
        "schema_version",
        "external_event_id",
        "source_event",
        "tool_name",
        "outcome",
        "diagnostic"
      ],
      "properties": {
        "schema_version": { "const": "apc.agent-event.v1" },
        "external_event_id": { "type": "string", "minLength": 1, "maxLength": 256 },
        "source_event": {
          "enum": [
            "start", "tool", "waiting", "review", "done", "failed",
            "SessionStart", "Setup", "InstructionsLoaded", "UserPromptSubmit", "UserPromptExpansion", "PreToolUse", "PermissionRequest",
            "PostToolUse", "PostToolUseFailure", "Stop", "StopFailure",
            "SessionEnd", "Notification", "Elicitation", "ElicitationResult",
            "PostToolBatch", "PermissionDenied", "PreCompact", "PostCompact",
            "SubagentStart", "SubagentStop", "TaskCreated", "TaskCompleted", "TeammateIdle", "ConfigChange", "CwdChanged", "WorktreeRemove",
            "session_start", "input", "before_agent_start", "agent_start", "turn_start", "turn_end", "message_end", "agent_end", "session_shutdown", "tool_call",
            "tool_execution_start", "tool_execution_end", "agent_settled", "session_before_compact", "session_compact",
            "session.created", "session.deleted", "session.status", "session.idle", "session.error",
            "permission.asked", "permission.updated", "permission.replied",
            "permission.v2.asked", "permission.v2.replied",
            "question.asked", "question.replied", "question.rejected",
            "question.v2.asked", "question.v2.replied", "question.v2.rejected",
            "session.next.prompt.admitted", "session.next.step.ended", "session.next.step.failed",
            "message.user", "message.assistant",
            "tool.execute.before", "tool.execute.after", "command.execute.before", "command.execute.after",
            "session.compaction.started", "session.compaction.ended", "session.plan.updated", "connector.probe",
            "connection.test", "app_server_activity", "legacy",
            "unclassified"
          ]
        },
        "contract_version": { "type": ["string", "null"], "maxLength": 128 },
        "tool_name": {
          "type": ["string", "null"],
          "enum": ["shell", "filesystem", "editor", "search", "network", "agent", "other", null]
        },
        "outcome": {
          "type": ["string", "null"],
          "enum": [
            "started", "completed", "permission_requested", "tool_failure",
            "api_failure", "settled", "created", "idle", "busy", "retry",
            "permission_replied", "permission_replied_once", "permission_replied_always",
            "permission_replied_allow", "permission_replied_deny", "permission_replied_reject",
            "started_without_args", "session_failure", "session_closed", "input_requested", "observed", "auto_denied",
            "background_active", "agent_completed", "message", "continued", "prompt_admitted", "unknown", null
          ]
        },
        "diagnostic": { "type": "boolean" },
        "affects_activity": { "type": "boolean" },
        "turn_id": { "type": ["string", "null"], "maxLength": 256 },
        "session_active": { "type": "boolean" },
        "message_role": { "type": ["string", "null"], "enum": ["user", "assistant", null] },
        "message_content": { "type": ["string", "null"], "maxLength": 4096 },
        "activity_kind": {
          "type": ["string", "null"],
          "enum": ["thinking", "plan", "command", "file", "file_change", "tool", "subagent", "search", "network", "image", "compaction", null]
        },
        "activity_content": { "type": ["string", "null"], "maxLength": 1024 },
        "interaction_kind": {
          "type": ["string", "null"],
          "enum": ["approval_required", "input_required", "review_required", null]
        },
        "project_label": { "type": ["string", "null"], "maxLength": 128 },
        "session_title": { "type": ["string", "null"], "maxLength": 160 },
        "session_open": { "type": ["boolean", "null"] },
        "session_surface": {
          "type": ["string", "null"],
          "enum": ["chatgpt_app", "cli_terminal", "unknown", null]
        },
        "terminal_app": {
          "type": ["string", "null"],
          "enum": ["warp", "terminal", "iterm2", "ghostty", "unknown", null]
        },
        "session_open_url": {
          "type": ["string", "null"],
          "maxLength": 256,
          "pattern": "^(warp|warppreview)://session/[0-9A-Fa-f]{32}$"
        }
      },
      "additionalProperties": false
    }
  }
}
